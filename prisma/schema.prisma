generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  OWNER
  MEMBER
}

enum CaseSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseType {
  MANUAL
  AUTOMATED
}

enum CaseStatus {
  UNTESTED
  PASSED
  FAILED
  BLOCKED
}

enum RunStatus {
  QUEUED
  RUNNING
  PASSED
  FAILED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects ProjectMember[]
  runs     TestRun[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  version     String   @default("1.0.0")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   ProjectMember[]
  folders   Folder[]
  testCases TestCase[]
  runs      TestRun[]
}

model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      ProjectRole @default(MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]   @relation("FolderTree")
  testCases TestCase[]

  @@index([projectId])
  @@index([parentId])
}

model TestCase {
  id               String       @id @default(cuid())
  code             String
  title            String
  description      String?
  preconditions    String?
  testData         String?
  finalExpectation String?
  actualResult     String?
  severity         CaseSeverity @default(MEDIUM)
  type             CaseType     @default(MANUAL)
  status           CaseStatus   @default(UNTESTED)
  projectId        String
  folderId         String?
  archived         Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  steps   Step[]
  tags    CaseTag[]
  results RunResult[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([folderId])
  @@index([archived])
  @@index([status])
  @@index([severity])
}

model Step {
  id         String  @id @default(cuid())
  order      Int
  action     String
  expected   String?
  testCaseId String

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, order])
  @@index([testCaseId])
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  cases CaseTag[]
}

model CaseTag {
  testCaseId String
  tagId      String

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([testCaseId, tagId])
  @@index([tagId])
}

model TestRun {
  id        String    @id @default(cuid())
  name      String
  projectId String
  userId    String
  status    RunStatus @default(QUEUED)
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  results RunResult[]

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model RunResult {
  id          String     @id @default(cuid())
  runId       String
  testCaseId  String
  status      CaseStatus @default(UNTESTED)
  duration    Int?
  error       String?
  notes       String?
  stepResults Json?
  executedAt  DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  run      TestRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Restrict)

  @@unique([runId, testCaseId])
  @@index([testCaseId])
  @@index([status])
  @@index([executedAt])
}