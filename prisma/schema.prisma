generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects ProjectMember[]
  runs     TestRun[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  version     String   @default("1.0.0")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   ProjectMember[]
  folders   Folder[]
  testCases TestCase[]
  runs      TestRun[]
}

model ProjectMember {
  id        String @id @default(cuid())
  userId    String
  projectId String
  role      String @default("MEMBER")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// Folders group test cases - can be nested (parent/children)
model Folder {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id])
  children  Folder[]   @relation("FolderTree")
  testCases TestCase[]
}

model TestCase {
  id          String   @id @default(cuid())
  code        String
  title       String
  description String?
  preconditions String?
  testData    String?
  finalExpectation String?
  actualResult String?
  severity    String   @default("MEDIUM")
  type        String   @default("MANUAL")
  status      String   @default("UNTESTED")
  projectId   String
  folderId    String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  Folder?     @relation(fields: [folderId], references: [id])
  steps   Step[]
  tags    CaseTag[]
  results RunResult[]
}

model Step {
  id         String  @id @default(cuid())
  order      Int
  action     String
  expected   String?
  testCaseId String

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
}

model Tag {
  id   String    @id @default(cuid())
  name String    @unique
  cases CaseTag[]
}

model CaseTag {
  testCaseId String
  tagId      String

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([testCaseId, tagId])
}

model TestRun {
  id        String    @id @default(cuid())
  name      String
  projectId String
  userId    String
  status    String    @default("QUEUED")
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])
  results RunResult[]
}

model RunResult {
  id         String   @id @default(cuid())
  runId      String
  testCaseId String
  status     String   @default("UNTESTED")
  duration   Int?
  error      String?
  notes      String?
  stepResults String? // JSON string: [{stepId, status, actual}]
  executedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  run      TestRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase TestCase @relation(fields: [testCaseId], references: [id])

  @@unique([runId, testCaseId])
}
